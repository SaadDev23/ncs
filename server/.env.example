# MongoDB Atlas connection string. Keep the real value only in server/.env.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/ncs?retryWrites=true&w=majority

# Resend email delivery. EMAIL_FROM must use a sender/domain verified in Resend.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Neo Code Syndicate <noreply@your-verified-domain.com>

# Optional: use only if your network cannot resolve Atlas SRV records.
# MONGODB_DNS_SERVER=8.8.8.8,1.1.1.1
